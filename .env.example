# ─────────────────────────────────────────────────────────────────────────────
# COT Tracker — Variables de Entorno
# ─────────────────────────────────────────────────────────────────────────────
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas el archivo .env al repositorio.
# Configura estas variables en Vercel Dashboard → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Autenticación (Google Apps Script) ───────────────────────────────────────
# URL completa del Google Apps Script que gestiona usuarios en Google Sheets.
# Ejemplo: https://script.google.com/macros/s/XXXX/exec
# OBLIGATORIO — sin esta variable /api/auth devuelve 503
SHEETS_SCRIPT_URL=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Origen permitido para CORS en producción.
# En desarrollo puedes dejar vacío (acepta *).
# En producción pon tu dominio: https://cot-tracker.vercel.app
FRONTEND_ORIGIN=

# ── Financial Modeling Prep (FMP) ────────────────────────────────────────────
# API key de FMP para datos financieros adicionales (si se usa).
# Configurada en Vercel como variable de entorno, NO en código.
FMP_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# INSTRUCCIONES PARA VERCEL:
# 1. Ve a cot-tracker → Settings → Environment Variables
# 2. Añade SHEETS_SCRIPT_URL con la URL de tu Apps Script
# 3. Añade FRONTEND_ORIGIN con https://cot-tracker.vercel.app
# 4. Haz redeploy
# ─────────────────────────────────────────────────────────────────────────────
